<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotSoForgottenCemetery.Template.FlyoutHeader">
    <Grid BackgroundColor="#1A1A1D" HeightRequest="200">
        <Image Source="mist_background.png" 
               Aspect="AspectFill" 
               Opacity="0.4" />
        
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
            <Label Text="🕯️" FontSize="48" HorizontalOptions="Center" />
            <Label Text="Not-So-Forgotten" 
                   TextColor="#D4AF37" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />
            <Label Text="Cemetery" 
                   TextColor="#D4AF37" 
                   FontSize="16" 
                   HorizontalOptions="Center" 
                   Margin="0,-10,0,0"/>
        </VerticalStackLayout>
    </Grid>
</ContentView>
