<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NotSoForgottenCemetery.Pages.HomePage"
             x:Class="NotSoForgottenCemetery.Pages.HomePage.HomePage"
             BackgroundColor="{StaticResource Black}"
             Title="Not-So-Forgotten">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">
            <!-- Header Section -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="Not-So-Forgotten Cemetery" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       TextColor="{StaticResource Tertiary}" 
                       HorizontalOptions="Center" />
                <Label Text="A professional space for memories and atmosphere." 
                       FontSize="14" 
                       TextColor="{StaticResource MistGray}" 
                       HorizontalOptions="Center" />
                <BoxView HeightRequest="1" 
                         WidthRequest="100"
                         Color="{StaticResource Tertiary}" 
                         HorizontalOptions="Center" 
                         Margin="0,8,0,0"/>
            </VerticalStackLayout>

            <!-- Status Section (Clock & Radio) -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="16">
                <!-- Clock Card -->
                <Border Grid.Column="0" 
                        Padding="16" 
                        BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                        <Label Text="Current Time" FontSize="11" TextColor="{StaticResource MistGray}" HorizontalOptions="Center"/>
                        <Label Text="{Binding ClockTime}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource White}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Radio Status -->
                <Border Grid.Column="1" 
                        Padding="16" 
                        BackgroundColor="{StaticResource Secondary}"
                        StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                        <Label Text="Radio Station" FontSize="11" TextColor="{StaticResource MistGray}" HorizontalOptions="Center"/>
                        <Label Text="{Binding CurrentSong}" 
                               FontSize="12" 
                               TextColor="{StaticResource Tertiary}" 
                               HorizontalOptions="Center" 
                               HorizontalTextAlignment="Center"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Memory Whisper (Clean Alert) -->
            <Border Padding="16" 
                    BackgroundColor="{StaticResource Primary}"
                    Stroke="{StaticResource Gray600}"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Whisper from the mist" FontSize="11" TextColor="{StaticResource Tertiary}" FontAttributes="Bold" />
                    <Label Text="{Binding CurrentWhisper}" FontSize="14" TextColor="{StaticResource White}" FontAttributes="Italic" />
                </VerticalStackLayout>
            </Border>

            <!-- Action Section: Engrave Memory -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Record a New Memory" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource White}" />
                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="8" ColumnSpacing="8">
                    <Entry Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                           Text="{Binding NewMemoryTitle}" 
                           Placeholder="Memory Title" />
                    <Editor Grid.Row="1" Grid.Column="0" 
                            Text="{Binding NewMemoryDescription}" 
                            Placeholder="Describe the memory..." 
                            HeightRequest="60" />
                    <Button Grid.Row="1" Grid.Column="1" 
                            Text="Save" 
                            Command="{Binding AddMemoryCommand}" 
                            WidthRequest="80" 
                            VerticalOptions="Fill" />
                </Grid>
            </VerticalStackLayout>

            <!-- Navigation Quick Links -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Button Grid.Column="0" Text="Browse Graveyard" Command="{Binding GoToMemoryBoardCommand}" BackgroundColor="{StaticResource Primary}" TextColor="{StaticResource White}" />
                <Button Grid.Column="1" Text="Manage Playlists" Command="{Binding GoToPlaylistsCommand}" BackgroundColor="{StaticResource Primary}" TextColor="{StaticResource White}" />
            </Grid>

            <!-- Recent Activity List -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Recent Memories" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource MistGray}" />
                <CollectionView ItemsSource="{Binding Memories}" ItemsLayout="VerticalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="12" BackgroundColor="{StaticResource OffBlack}" StrokeShape="RoundRectangle 4">
                                <HorizontalStackLayout Spacing="12">
                                    <BoxView WidthRequest="2" BackgroundColor="{StaticResource Tertiary}" VerticalOptions="Fill" />
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource White}" />
                                        <Label Text="{Binding Description}" FontSize="12" TextColor="{StaticResource MistGray}" LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>