<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cemetery"
             x:Class="Cemetery.HomePage"
             x:DataType="local:HomeViewModel"
             BackgroundColor="{StaticResource Black}">
    <Grid RowDefinitions="Auto, *">

        <!-- Header / Clock -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource Secondary}" Padding="24,28" StrokeThickness="0">
            <VerticalStackLayout Spacing="4">
                <Label Text="MEMORIAL DASHBOARD"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="3"
                       TextColor="{StaticResource Tertiary}"
                       HorizontalOptions="Center" />
                <Label Text="{Binding ClockTime}"
                       FontSize="52"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       HorizontalOptions="Center" />
                <Label Text="{Binding CurrentSong}"
                       FontSize="13"
                       TextColor="{StaticResource MistGray}"
                       HorizontalOptions="Center"
                       FontAttributes="Italic" />
            </VerticalStackLayout>
        </Border>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24" Spacing="24">

                <!-- Whisper -->
                <Label Text="{Binding CurrentWhisper}"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Tertiary}"
                       FontSize="15"
                       FontAttributes="Italic"
                       Margin="0,8,0,0" />

                <!-- Quick Navigation -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="16">
                    <Border Grid.Column="0" BackgroundColor="{StaticResource Secondary}" Padding="20" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToMemoryBoardCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="📜" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Archive" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Tertiary}" HorizontalOptions="Center" />
                            <Label Text="View all records" FontSize="11" TextColor="{StaticResource MistGray}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="{StaticResource Secondary}" Padding="20" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToPlaylistsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="🎵" FontSize="28" HorizontalOptions="Center" />
                            <Label Text="Music" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource Tertiary}" HorizontalOptions="Center" />
                            <Label Text="Curated playlists" FontSize="11" TextColor="{StaticResource MistGray}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Add Memory Panel -->
                <Border BackgroundColor="{StaticResource Secondary}" Padding="24" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Record a New Memory"
                               FontAttributes="Bold"
                               FontSize="15"
                               TextColor="{StaticResource Tertiary}" />
                        <Entry Placeholder="Memory Title"
                               Text="{Binding NewMemoryTitle}"
                               TextColor="{StaticResource White}"
                               PlaceholderColor="{StaticResource MistGray}" />
                        <Editor Placeholder="Details..."
                                Text="{Binding NewMemoryDescription}"
                                HeightRequest="80"
                                TextColor="{StaticResource White}"
                                PlaceholderColor="{StaticResource MistGray}" />
                        <Button Text="Commit to Archive"
                                Command="{Binding AddMemoryCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="{StaticResource White}"
                                CornerRadius="8" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
