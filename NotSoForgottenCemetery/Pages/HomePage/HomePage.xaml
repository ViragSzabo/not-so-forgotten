<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NotSoForgottenCemetery.Pages.HomePage"
             x:Class="NotSoForgottenCemetery.Pages.HomePage.HomePage"
             BackgroundColor="#1A1A1D">

    <ScrollView>
        <VerticalStackLayout Padding="20,40,20,20" Spacing="20">
            <!-- Header -->
            <Label Text="🕯️ Not-So-Forgotten Cemetery" FontSize="Title" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="Center" />
            <Label Text="A gothic autumn radio that whispers memories." FontSize="Subtitle" FontAttributes="Italic" TextColor="#A9A9A9" HorizontalOptions="Center" />
            
            <BoxView HeightRequest="1" Color="#4A4A4A" Margin="0,10" />

            <!-- Clockwork -->
            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="10">
                <Label Text="🕰️" FontSize="24" VerticalOptions="Center" />
                <Label Text="{Binding ClockTime}" FontSize="24" TextColor="#E0E0E0" VerticalOptions="Center" />
            </StackLayout>

            <!-- Radio Station -->
            <Frame BackgroundColor="#2D2D30" CornerRadius="10" Padding="15" BorderColor="#4A4A4A">
                <VerticalStackLayout Spacing="5">
                    <Label Text="🎙️ Radio Station" FontSize="Body" FontAttributes="Bold" TextColor="#D4AF37" />
                    <Label Text="{Binding CurrentSong}" FontSize="Body" TextColor="#B0B0B0" FontAttributes="Italic" />
                    <Button Text="Watch on YouTube" 
                            Command="{Binding WatchOnYouTubeCommand}"
                            BackgroundColor="#CC0000"
                            TextColor="White"
                            HeightRequest="30"
                            Padding="10,0"
                            FontSize="12"
                            CornerRadius="5"
                            HorizontalOptions="Start"
                            Margin="0,5,0,0" />
                </VerticalStackLayout>
            </Frame>

            <!-- Memory Whispers -->
            <Frame BackgroundColor="#222222" CornerRadius="10" Padding="15" BorderColor="#4A4A4A" Opacity="0.9">
                <VerticalStackLayout Spacing="5">
                    <Label Text="🌫️ Whisper in the mist:" FontSize="Body" FontAttributes="Bold" TextColor="#D4AF37" />
                    <Label Text="{Binding CurrentWhisper}" FontSize="Body" TextColor="#C0C0C0" FontAttributes="Italic" />
                </VerticalStackLayout>
            </Frame>

            <BoxView HeightRequest="1" Color="#4A4A4A" Margin="0,10" />

            <!-- Add Memory Section -->
            <Label Text="🪦 Engrave a Memory" FontSize="Body" FontAttributes="Bold" TextColor="#D4AF37" />
            <Entry Text="{Binding NewMemoryTitle}" Placeholder="Title..." PlaceholderColor="#696969" TextColor="White" BackgroundColor="#2D2D30" />
            <Editor Text="{Binding NewMemoryDescription}" Placeholder="Memory..." PlaceholderColor="#696969" TextColor="White" BackgroundColor="#2D2D30" HeightRequest="80" />
            <Button Text="Rest in Peace" Command="{Binding AddMemoryCommand}" BackgroundColor="#4A0000" TextColor="#FFF" CornerRadius="8" />

            <!-- Navigation Buttons -->
            <StackLayout Orientation="Horizontal" Spacing="10" HorizontalOptions="Center" Margin="0,10,0,0">
                <Button Text="Graves" Command="{Binding GoToMemoryBoardCommand}" BackgroundColor="#2D2D30" TextColor="#D4AF37" />
                <Button Text="Playlists" Command="{Binding GoToPlaylistsCommand}" BackgroundColor="#2D2D30" TextColor="#D4AF37" />
            </StackLayout>

            <!-- Digital Cemetery -->
            <Label Text="Recent Memories" FontSize="Subtitle" FontAttributes="Bold" TextColor="#A9A9A9" Margin="0,10,0,0" />
            <CollectionView ItemsSource="{Binding Memories}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="10" Margin="0,5" BackgroundColor="#2D2D30">
                            <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="#D4AF37" />
                            <Label Text="{Binding Description}" TextColor="#E0E0E0" />
                            <Label Text="{Binding Date, StringFormat='{0:MMM dd, yyyy}'}" FontSize="Micro" TextColor="#808080" />
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>