<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cemetery"
             xmlns:vm="clr-namespace:Cemetery.ViewModels"
             x:Class="Cemetery.PlayListPage"
             x:DataType="vm:PlaylistViewModel"
             BackgroundColor="{StaticResource Black}"
             Title="Music Repository">
    <VerticalStackLayout Padding="24" Spacing="24">
        <VerticalStackLayout Spacing="8">
            <Label Text="Curated Playlists"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Tertiary}" />
            <Label Text="Your music, thoughtfully organised."
                   FontSize="13"
                   TextColor="{StaticResource MistGray}"
                   FontAttributes="Italic" />
            <BoxView HeightRequest="1" Color="{StaticResource Tertiary}" Margin="0,4,0,0"/>
        </VerticalStackLayout>

        <CollectionView ItemsSource="{Binding Playlists}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:PlaylistDb">
                    <Border BackgroundColor="{StaticResource Secondary}"
                            Margin="0,0,0,12"
                            Padding="18"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Name}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource White}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="▶ Listen"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PlaylistViewModel}}, Path=OpenCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource White}"
                                    CornerRadius="6" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
