<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NotSoForgottenCemetery.Pages.MemoryBoard"
             xmlns:models="clr-namespace:NotSoForgottenCemetery.Models"
             xmlns:helpers="clr-namespace:NotSoForgottenCemetery.Helpers"
             x:Class="NotSoForgottenCemetery.Pages.MemoryBoardPage.MemoryBoardPage"
             x:DataType="vm:MemoryBoardViewModel"
             BackgroundColor="{StaticResource Black}"
             Title="Memory Archive">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="24">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="The Memory Archive" 
                           FontSize="32" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource Tertiary}" 
                           HorizontalOptions="Center" />
                    <Label Text="A professional repository of cherished moments."
                           TextColor="{StaticResource MistGray}"
                           FontSize="14"
                           HorizontalOptions="Center"
                           FontAttributes="Italic"/>
                    <BoxView HeightRequest="1" WidthRequest="150" Color="{StaticResource Tertiary}" HorizontalOptions="Center" Margin="0,8,0,0"/>
                </VerticalStackLayout>

                <CollectionView ItemsSource="{Binding Memories}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" 
                                          Span="2" 
                                          HorizontalItemSpacing="16" 
                                          VerticalItemSpacing="24" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MemoryDb">
                            <!-- Professional Card -->
                            <Border BackgroundColor="{StaticResource Secondary}" 
                                    Padding="1" 
                                    Stroke="{StaticResource Gray600}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8">
                                <Grid RowDefinitions="140, Auto">
                                    <!-- Image Profile -->
                                    <Border Grid.Row="0" Margin="8,8,8,0" Padding="0" StrokeShape="RoundRectangle 4" IsClippedToBounds="True">
                                        <Image Source="{Binding ImagePath}" 
                                               Aspect="AspectFill" />
                                    </Border>

                                    <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                                        <Label Text="{Binding Title}" 
                                               FontSize="16" 
                                               FontAttributes="Bold" 
                                               TextColor="{StaticResource White}" 
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation" />
                                        
                                        <Label Text="{Binding Date, StringFormat='{0:yyyy}'}" 
                                               FontSize="11" 
                                               TextColor="{StaticResource MistGray}" 
                                               HorizontalOptions="Center" />

                                        <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="0,8,0,0">
                                            <Button Grid.Column="0" 
                                                    Text="Listen" 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MemoryBoardViewModel}}, Path=ListenOnSpotifyCommand}" 
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{StaticResource Primary}" 
                                                    TextColor="{StaticResource White}"
                                                    HeightRequest="36"
                                                    FontSize="11" 
                                                    Padding="0" />
                                            
                                            <Button Grid.Column="1" 
                                                    Text="Watch" 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MemoryBoardViewModel}}, Path=WatchOnYouTubeCommand}" 
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{StaticResource Primary}" 
                                                    TextColor="{StaticResource White}"
                                                    HeightRequest="36"
                                                    FontSize="11" 
                                                    Padding="0" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
tPage>