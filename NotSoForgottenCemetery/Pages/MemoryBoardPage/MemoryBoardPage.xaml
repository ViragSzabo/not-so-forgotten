<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cemetery"
             x:Class="Cemetery.MemoryBoardPage"
             x:DataType="local:MemoryBoardViewModel"
             BackgroundColor="{StaticResource Black}"
             Title="Memory Archive">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="24">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="The Memory Archive"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Tertiary}"
                           HorizontalOptions="Center" />
                    <Label Text="A repository of cherished moments."
                           TextColor="{StaticResource MistGray}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           FontAttributes="Italic"/>
                    <BoxView HeightRequest="1" WidthRequest="120" Color="{StaticResource Tertiary}" HorizontalOptions="Center" Margin="0,8,0,0"/>
                </VerticalStackLayout>

                <CollectionView ItemsSource="{Binding Memories}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="2"
                                         HorizontalItemSpacing="16"
                                         VerticalItemSpacing="16" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:MemoryDb">
                            <Border BackgroundColor="{StaticResource Secondary}"
                                    Padding="14"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding Title}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource White}"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Date, StringFormat='{0:MMMM yyyy}'}"
                                           FontSize="11"
                                           TextColor="{StaticResource MistGray}"
                                           HorizontalOptions="Center" />
                                    <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="0,8,0,0">
                                        <Button Grid.Column="0"
                                                Text="Spotify"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type local:MemoryBoardViewModel}}, Path=ListenOnSpotifyCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource Primary}"
                                                TextColor="{StaticResource White}"
                                                CornerRadius="6"
                                                HeightRequest="36"
                                                FontSize="11" />
                                        <Button Grid.Column="1"
                                                Text="YouTube"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type local:MemoryBoardViewModel}}, Path=WatchOnYouTubeCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource Primary}"
                                                TextColor="{StaticResource White}"
                                                CornerRadius="6"
                                                HeightRequest="36"
                                                FontSize="11" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
